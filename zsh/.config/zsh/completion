#!/usr/bin/env zsh

# Enable advanced completion system
zmodload zsh/complist

# Create cache dir if dne
[ -d "$XDG_CACHE_HOME"/zsh ] || mkdir -p "$XDG_CACHE_HOME"/zsh

# Add user-specific completions (machine-local, not in dotfiles)
[ -d "$HOME/.local/share/zsh/completions" ] && fpath=("$HOME/.local/share/zsh/completions" $fpath)

# Add ~/.zfunc for tools that write completions there (e.g. typer, some Python tools)
[ -d "$HOME/.zfunc" ] && fpath=("$HOME/.zfunc" $fpath)

# Add homebrew based completions if using brew
if command -v brew &>/dev/null; then
    fpath=(/opt/homebrew/share/zsh/site-functions $fpath)
fi

# Setup completion styles and options
autoload -U compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' cache-path "$XDG_CACHE_HOME"/zsh/zcompcache
_comp_options+=(globdots)  # Include hidden files in completion

# Initialize completion system with versioned dump
compinit -d "$XDG_CACHE_HOME"/zsh/zcompdump-$ZSH_VERSION

# Terraform completion (uses bash-style completion)
if command -v terraform &>/dev/null; then
    autoload -U +X bashcompinit && bashcompinit
    complete -o nospace -C "$(command -v terraform)" terraform
fi
